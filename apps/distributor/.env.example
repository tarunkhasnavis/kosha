# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Token encryption (64-char hex string)
TOKEN_ENCRYPTION_KEY=your-64-char-hex-string

# Resend (email sending)
RESEND_API_KEY=re_your-resend-key

# Database (optional)
# DATABASE_URL=postgresql://...

# QuickBooks Online (optional)
# QUICKBOOKS_CLIENT_ID=your-qb-client-id
# QUICKBOOKS_CLIENT_SECRET=your-qb-client-secret
# QUICKBOOKS_ENVIRONMENT=sandbox
# QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=your-verifier-token

# QuickBooks Desktop via Conductor (optional)
# CONDUCTOR_SECRET_KEY=your-conductor-secret
# CONDUCTOR_PUBLISHABLE_KEY=your-conductor-publishable

# App URL (optional)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
